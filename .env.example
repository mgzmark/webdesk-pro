# Signaling server
HOST=0.0.0.0
PORT=3000

# Optional comma-separated allowlist for browser / Electron origins.
# Leave empty to allow any origin during local development.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Pending control request lifetime / heartbeat guardrails
REQUEST_TTL_MS=30000
HEARTBEAT_INTERVAL_MS=15000
PEER_STALE_MS=45000

# ICE / NAT traversal
STUN_URLS=stun:stun.l.google.com:19302,stun:global.stun.twilio.com:3478
TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
TURN_USERNAME=replace-me
TURN_CREDENTIAL=replace-me

# Electron Host / companion bridge can override the signaling endpoint:
# WS_URL=wss://your-domain.example/signaling
